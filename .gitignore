# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.p12
*.key

# pitch materials (repo is public — keep strategic / pricing docs out)
/docs/pitch/

# PassKit signing certs (NEVER commit — anyone with these can sign passes as us)
/scripts/pass-cert/

# Generated wallet passes — gitignored by default, with one exception below.
/public/passes/*.pkpass
# Demo founders pass IS committed so Vercel can serve it without rebuild
# infrastructure. Acceptable for the pitch demo (the pass identifies the
# pitch target, Tilman). For production, replace with a per-member API.
!/public/passes/founders.pkpass

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
